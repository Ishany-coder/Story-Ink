# StoryInk — example environment configuration.
#
# Copy this file to .env.local for local development:
#     cp .env.example .env.local
# and fill in the values below. .env.local is gitignored.
#
# IMPORTANT — Stripe test vs live:
#   The SAME env var name (STRIPE_SECRET_KEY) holds different values in
#   different environments. The Stripe SDK auto-detects mode from the
#   key prefix:
#       sk_test_…  → test mode (fake cards, no real money)
#       sk_live_…  → live mode (real cards, real money)
#   The runtime guard `assertStripeKeyMatchesEnv` hard-fails the boot if
#   a live key shows up in NODE_ENV != "production", or a test key in
#   production. Keep the streams uncrossed.

# ============================================================================
# Supabase — Postgres + Auth + Storage
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only. Bypasses RLS — DO NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ============================================================================
# Gemini — story text + illustration generation
# ============================================================================
GEMINI_API_KEY=...

# Optional. Parallel batch size for Quality-mode pet story image
# generation. Pages 1 and 2 are generated serially to lock the
# canonical character sheet + continuation anchor; pages 3..N are then
# generated in parallel batches of this size. Increase for faster
# wall-clock, decrease if you hit Gemini's per-minute image quota.
# Default: 4. Set to 1 to fall back to fully-serial behaviour.
# GEMINI_PARALLEL_BATCH=4

# ============================================================================
# Inngest — async job runner (story generation, AI assistant, etc.)
#   Local dev: leave both blank. NODE_ENV=development auto-uses the
#              `npx inngest-cli@latest dev` dev server on :8288.
#   Production: set both, from Inngest dashboard → Manage → Event keys
#               and Signing keys.
# ============================================================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================================================
# Stripe — payments
#
# LOCAL DEV (this file, .env.local):
#   STRIPE_SECRET_KEY=sk_test_…
#     From: Dashboard (top-right toggle: Test mode) → Developers → API keys
#   STRIPE_WEBHOOK_SECRET=whsec_…
#     From: terminal output of `stripe listen --forward-to localhost:3000/api/ship/stripe/webhook`
#     This secret rotates each time `stripe listen` starts — re-copy on
#     every new session.
#
# PRODUCTION:
#   STRIPE_SECRET_KEY=sk_live_…
#     From: Dashboard (Live mode) → Developers → API keys
#   STRIPE_WEBHOOK_SECRET=whsec_…
#     From: Dashboard → Workbench → your destination → Signing secret → Reveal
# ============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional admin-only escape hatch — skips Stripe entirely and flips
# digital_unlocked / creates a stub print order. Lets admins demo the
# unlocked reader and the fulfillment pipeline without a real charge.
# `assertNoBypassInProd` throws if this is set in production env.
# BYPASS_STRIPE=1

# ============================================================================
# Print fulfillment
#   No third-party print API is wired up — admins fulfill hardcover
#   orders manually. After a paid Stripe Checkout the webhook writes a
#   row to `print_orders` (status = "received") and generates the
#   interior + cover PDFs into Supabase Storage. The admin's /orders
#   queue surfaces those rows; admin downloads the PDFs and places the
#   order with whatever print/ship vendor they want, then ticks the
#   row through the status transitions.
# ============================================================================

# ============================================================================
# Misc
# ============================================================================
# Used to build success/cancel URLs for the digital-unlock checkout.
# Locally: http://localhost:3000
# Production: https://storyink.ai (or wherever you deploy)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional. Comma-separated extension to the SSRF allowlist used when
# fetching user-influenceable URLs (image grounding in Gemini, print PDF
# image embeds). Only widen this if you know what you're doing.
# ALLOWED_IMAGE_HOSTS=cdn.example.com,images.partner.com

# ============================================================================
# Resend — transactional email (order confirmation, shipped, account
# deletion). API key from resend.com. If unset, all email send calls
# no-op (logged only). Get from Resend → API Keys.
# ============================================================================
RESEND_API_KEY=

# Default sender for transactional email — must be a verified domain in
# the Resend dashboard. Configure DNS / verified domain on Resend
# (resend.com → Domains) BEFORE setting this to a real address.
# Example: "StoryInk <orders@storyink.com>"
EMAIL_FROM=

# ============================================================================
# Sentry — error tracking (optional)
# ============================================================================
# Server + client Sentry DSNs. If unset, Sentry is a no-op. Get from
# sentry.io project → Settings → Client Keys.
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# Closed-beta kill switch
# ============================================================================
# Set NEXT_PUBLIC_BETA_TESTING=1 to hide every hardcover-print / payment
# surface (the /ship + /my-orders routes 404, 'Order hardcover' CTAs
# disappear, no Stripe pricing shown, reader auto-unlocks). Story
# generation + reading still work. Unset for production launch.
#
# The NEXT_PUBLIC_ prefix is required so the same flag is readable in
# both server components and client components (Next.js only exposes
# NEXT_PUBLIC_*-prefixed vars to the browser bundle). A boolean
# kill-switch is not a secret, so single-var setup is fine. Don't add
# a parallel server-only BETA_TESTING — it's unnecessary and creates a
# mismatch risk if the two values ever diverge.
# NEXT_PUBLIC_BETA_TESTING=
