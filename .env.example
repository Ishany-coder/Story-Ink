# StoryInk — example environment configuration.
#
# Copy this file to .env.local for local development:
#     cp .env.example .env.local
# and fill in the values below. .env.local is gitignored.
#
# IMPORTANT — Stripe test vs live:
#   The SAME env var name (STRIPE_SECRET_KEY) holds different values in
#   different environments. The Stripe SDK auto-detects mode from the
#   key prefix:
#       sk_test_…  → test mode (fake cards, no real money)
#       sk_live_…  → live mode (real cards, real money)
#   The runtime guard `assertStripeKeyMatchesEnv` hard-fails the boot if
#   a live key shows up in NODE_ENV != "production", or a test key in
#   production. Keep the streams uncrossed.

# ============================================================================
# Supabase — Postgres + Auth + Storage
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only. Bypasses RLS — DO NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ============================================================================
# Gemini — story text + illustration generation
# ============================================================================
GEMINI_API_KEY=...

# ============================================================================
# Inngest — async job runner (story generation, AI assistant, etc.)
#   Local dev: leave both blank. NODE_ENV=development auto-uses the
#              `npx inngest-cli@latest dev` dev server on :8288.
#   Production: set both, from Inngest dashboard → Manage → Event keys
#               and Signing keys.
# ============================================================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ============================================================================
# Stripe — payments
#
# LOCAL DEV (this file, .env.local):
#   STRIPE_SECRET_KEY=sk_test_…
#     From: Dashboard (top-right toggle: Test mode) → Developers → API keys
#   STRIPE_WEBHOOK_SECRET=whsec_…
#     From: terminal output of `stripe listen --forward-to localhost:3000/api/ship/stripe/webhook`
#     This secret rotates each time `stripe listen` starts — re-copy on
#     every new session.
#
# PRODUCTION:
#   STRIPE_SECRET_KEY=sk_live_…
#     From: Dashboard (Live mode) → Developers → API keys
#   STRIPE_WEBHOOK_SECRET=whsec_…
#     From: Dashboard → Workbench → your destination → Signing secret → Reveal
# ============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional admin-only escape hatch — skips Stripe entirely and flips
# digital_unlocked / creates a stub print order. Lets admins demo the
# unlocked reader and the fulfillment pipeline without a real charge.
# `assertNoBypassInProd` throws if this is set in production env.
# BYPASS_STRIPE=1

# ============================================================================
# Lulu Direct — print + ship
#   Sandbox is free and prints nothing real. Set LULU_ENV=production
#   only when you're ready to print live books.
# ============================================================================
LULU_CLIENT_KEY=...
LULU_CLIENT_SECRET=...
# Omit (or set anything except "production") to use Lulu sandbox.
# LULU_ENV=production
# Optional override; default is 8.5×8.5" color hardcover casewrap.
# LULU_PRODUCT_SKU=0850X0850FCSTDCW060UW444GXX

# ============================================================================
# Misc
# ============================================================================
# Used to build success/cancel URLs for the digital-unlock checkout.
# Locally: http://localhost:3000
# Production: https://storyink.ai (or wherever you deploy)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional. Comma-separated extension to the SSRF allowlist used when
# fetching user-influenceable URLs (image grounding in Gemini, print PDF
# image embeds). Only widen this if you know what you're doing.
# ALLOWED_IMAGE_HOSTS=cdn.example.com,images.partner.com
